# Hedge Fund Research - Environment Variables
# Copy this file to .env and fill in your values.

# ============================================================================
# REQUIRED
# ============================================================================

# Anthropic API key for research orchestrator
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# OPTIONAL - Data Storage
# ============================================================================

# Path to data cache directory (default: ./data/cache)
# DATA_STORAGE_PATH=./data/cache

# Path to research database (default: DATA_STORAGE_PATH/research.duckdb)
# RESEARCH_DB_PATH=

# ============================================================================
# OPTIONAL - OpenBB Free API Keys
# ============================================================================

# FRED API key for macro economic data (GDP, CPI, rates, unemployment)
# Register for free at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep - 250 free API calls/day
# Register at: https://site.financialmodelingprep.com/developer/docs/pricing
# FMP_API_KEY=your_fmp_api_key_here

# ============================================================================
# OPTIONAL - Obsidian Integration
# ============================================================================

# Path to Obsidian vault (default: ./obsidian-vault)
# OBSIDIAN_VAULT_PATH=

# Project folder within vault (default: vault root)
# OBSIDIAN_PROJECT_FOLDER=

# ============================================================================
# OPTIONAL - Misc
# ============================================================================

# Logging level (default: INFO)
# LOG_LEVEL=INFO

# Politician signal lookback days (default: 45)
# POLITICIAN_SIGNAL_LOOKBACK_DAYS=45
