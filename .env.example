# Hedge Fund Research Configuration

# Data directory (defaults to ./data if not set)
DATA_DIR=./data

# StockTwits (optional - for social sentiment)
# Get API key from https://api.stocktwits.com/developers
STOCKTWITS_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=hedge-fund-research:v1.0

# Finnhub API (https://finnhub.io)
FINNHUB_API_KEY=your_api_key

